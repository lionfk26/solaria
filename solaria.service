[Unit]
Description=Solaria Local AI Server Engine (Pi Lite)
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=fred
WorkingDirectory=/home/fred/solaria
ExecStart=/bin/bash /home/fred/solaria/auto_run.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
